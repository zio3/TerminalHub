        // トグル切り替え時にMQTT接続/切断を即座に実行
        if (remoteLaunchEnabled && !string.IsNullOrEmpty(remoteLaunchTopicGuid))
        {
            await MqttService.ConnectAsync(remoteLaunchTopicGuid);
        }
        else
        {
            await MqttService.DisconnectAsync();
        }
    }

