    private IEnumerable<SessionInfo> GetAvailableSessions()
    {
        // ConPtySessionを持っていて、アーカイブされていないセッションだけを表示
        var activeSessions = SessionManager.GetAllSessions()
            .Where(s => !s.IsArchived && s.ConPtySession != null);

        // セッションリストと同じソート順
        if (SessionSortMode == "lastAccessed")
        {
            return activeSessions.OrderByDescending(s => s.LastAccessedAt);
        }
        else
        {
            return activeSessions.OrderBy(s => s.CreatedAt);
        }
    }

    private SessionInfo? GetSelectedBufferSession()
    {
        if (string.IsNullOrEmpty(selectedSessionForBuffer) || !Guid.TryParse(selectedSessionForBuffer, out var sessionId))
            return null;
        return SessionManager.GetSessionInfo(sessionId);
    }


    private async Task DownloadBuffer()
    {
        await WithSelectedBufferSession(sessionInfo =>
        {
            var content = sessionInfo.GetTerminalBuffer();
            if (string.IsNullOrEmpty(content))
                return Task.FromResult<(string?, string, string)?>(null);

            var bufferInfo = new
            {
                BufferSize = content.Length,
                LineCount = content.Split('\n').Length,
                DumpTime = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss"),
                SessionName = sessionInfo.GetDisplayName(),
                SessionId = sessionInfo.SessionId
            };
            var header = $"--- {L["Settings.DevBuffer.HeaderBufferInfo"]} ---\n"
                + System.Text.Json.JsonSerializer.Serialize(bufferInfo, new System.Text.Json.JsonSerializerOptions { WriteIndented = true })
                + $"\n\n--- {L["Settings.DevBuffer.HeaderBufferContent"]} ---\n";

            return Task.FromResult<(string?, string, string)?>(
                (header + content, $"buffer_{SanitizeFilename(sessionInfo.GetDisplayName())}_{DateTime.Now:yyyyMMdd_HHmmss}.txt", "text/plain"));
        });
    }

    private async Task DownloadBufferClean()
    {
        await WithSelectedBufferSession(sessionInfo =>
        {
            var content = sessionInfo.GetTerminalBuffer();
            if (string.IsNullOrEmpty(content))
                return Task.FromResult<(string?, string, string)?>(null);

            var cleanedContent = Helpers.AnsiHelper.CleanAnsiSequences(content);
            return Task.FromResult<(string?, string, string)?>(
                (cleanedContent, $"buffer_clean_{SanitizeFilename(sessionInfo.GetDisplayName())}_{DateTime.Now:yyyyMMdd_HHmmss}.txt", "text/plain"));
        });
    }

    private async Task DownloadStatusHistory()
    {
        await WithSelectedBufferSession(sessionInfo =>
        {
            var history = sessionInfo.GetStatusChangeHistory();
            if (history.Count == 0)
                return Task.FromResult<(string?, string, string)?>(null);

            var exportData = new
            {
                SessionName = sessionInfo.GetDisplayName(),
                SessionId = sessionInfo.SessionId,
                ExportTime = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss"),
                TotalEntries = history.Count,
                Entries = history.Select(e => new
                {
                    Timestamp = e.Timestamp.ToString("yyyy-MM-dd HH:mm:ss.fff"),
                    Previous = e.PreviousStatus ?? "(idle)",
                    Current = e.NewStatus ?? "(idle)",
                    MatchedText = e.MatchedText
                }).ToList()
            };

            var json = System.Text.Json.JsonSerializer.Serialize(exportData, new System.Text.Json.JsonSerializerOptions
            {
                WriteIndented = true,
                Encoder = System.Text.Encodings.Web.JavaScriptEncoder.UnsafeRelaxedJsonEscaping
            });

            return Task.FromResult<(string?, string, string)?>(
                (json, $"status_history_{SanitizeFilename(sessionInfo.GetDisplayName())}_{DateTime.Now:yyyyMMdd_HHmmss}.json", "application/json"));
        });
    }

    /// <summary>
    /// バッファダウンロード共通処理。コールバックが (content, filename, mimeType) を返すとダウンロード実行。null を返すとバッファ空扱い。
    /// </summary>
    private async Task WithSelectedBufferSession(Func<SessionInfo, Task<(string? Content, string Filename, string MimeType)?>> contentFactory)
    {
        try
        {
            var sessionInfo = GetSelectedBufferSession();
            if (sessionInfo == null)
            {
                bufferResult = L["Settings.DevBuffer.Result.SelectSession"];
                return;
            }

            var result = await contentFactory(sessionInfo);
            if (result == null || result.Value.Content == null)
            {
                bufferResult = L["Settings.DevBuffer.Result.BufferEmpty"];
                return;
            }

            var (content, filename, mimeType) = result.Value;
            var bytes = System.Text.Encoding.UTF8.GetBytes(content);
            var base64 = Convert.ToBase64String(bytes);

            await JSRuntime.InvokeVoidAsync("terminalHubHelpers.downloadBase64File", base64, filename, mimeType);
            bufferResult = string.Format(L["Settings.DevBuffer.Result.DownloadedFormat"], filename, FormatBytes(content.Length));
        }
        catch (Exception ex)
        {
            bufferResult = string.Format(L["Common.ErrorFormat"], ex.Message);
        }
    }

    private string FormatBytes(int bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    private string SanitizeFilename(string filename)
    {
        var invalidChars = Path.GetInvalidFileNameChars();
        var sanitized = filename;
        foreach (var c in invalidChars)
        {
            sanitized = sanitized.Replace(c, '_');
        }
        return sanitized;
    }

