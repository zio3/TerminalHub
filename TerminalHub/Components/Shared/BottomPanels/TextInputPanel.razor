    public async ValueTask DisposeAsync()
    {
        SlashCommandProvider.Changed -= OnSlashCatalogChanged;

        if (_slashRegistered)
        {
            try
            {
                await JS.InvokeVoidAsync("slashAutocomplete.unregister", $"inputText-{PanelId}");
            }
            catch
            {
                // JSDisconnectedException 等は無視
            }
        }
        _slashDotNetRef?.Dispose();

        if (voiceInitialized)
        {
            try
            {
                await JS.InvokeVoidAsync("voiceInputManager.unbindMiddlePushToTalk", $"inputText-{PanelId}");
            }
            catch { /* Dispose 経路。JSDisconnectedException 等は無視 */ }
            try
            {
                await JS.InvokeVoidAsync("voiceInputManager.unbindSpaceHoldPushToTalk", $"inputText-{PanelId}");
            }
            catch { /* 同上 */ }
            try
            {
                await JS.InvokeVoidAsync("voiceInputManager.dispose");
            }
            catch
            {
                // JSDisconnectedException等は無視
            }
        }
        dotNetRef?.Dispose();
    }
}
