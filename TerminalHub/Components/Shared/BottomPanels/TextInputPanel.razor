    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // 未登録の間は毎レンダーで登録を試みる（設定ON化やセッション切替後に後追いで付くように）。
        if (!_slashRegistered)
        {
            await TryRegisterSlashAutocomplete();
        }

        if (firstRender && VoiceInputEnabled)
        {
            await InitVoiceInput();
            // 中ボタン Push-to-Talk バインド
            try
            {
                await JS.InvokeVoidAsync("voiceInputManager.bindMiddlePushToTalk",
                    $"inputText-{PanelId}", dotNetRef);
            }
            catch { /* バインド失敗時は該当 Push-to-Talk が無効になるだけ。回線切断時の例外含め無視 */ }
            // スペース長押し Push-to-Talk バインド
            try
            {
                await JS.InvokeVoidAsync("voiceInputManager.bindSpaceHoldPushToTalk",
                    $"inputText-{PanelId}", dotNetRef);
            }
            catch { /* 同上（バインド失敗＝機能縮退のみ） */ }
        }
    }

    private async Task InitVoiceInput()
    {
        if (voiceInitialized) return;
        try
        {
            dotNetRef = DotNetObjectReference.Create(this);
            var supported = await JS.InvokeAsync<bool>("voiceInputManager.isSupported");
            if (supported)
            {
                await JS.InvokeAsync<bool>("voiceInputManager.init", dotNetRef);
                voiceInitialized = true;
            }
        }
        catch
        {
            // JSInteropエラーは無視
        }
    }

    private async Task OnVoiceStart()
    {
        if (!voiceInitialized)
        {
            await InitVoiceInput();
            if (!voiceInitialized) return;
        }
        isVoiceRecording = true;
        try
        {
            await JS.InvokeVoidAsync("voiceInputManager.startRecording", $"inputText-{PanelId}");
        }
        catch
        {
            isVoiceRecording = false;
        }
    }

    private async Task OnVoiceStop()
    {
        if (!isVoiceRecording) return;
        isVoiceRecording = false;
        try
        {
            await JS.InvokeVoidAsync("voiceInputManager.stopRecording");
        }
        catch
        {
            // JSInteropエラーは無視
        }
    }

    [JSInvokable]
    public void OnVoiceResult(string text)
    {
        inputText = text;
        StateHasChanged();
    }

    /// <summary>
    /// テキストエリア上で中マウスボタンが押されたとき、JS から呼ばれる。
