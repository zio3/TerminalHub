    private async Task RemoveSession(Guid sessionId)
    {
        // 削除確認
        var sessionToRemove = sessions.FirstOrDefault(s => s.SessionId == sessionId);
        if (sessionToRemove != null)
        {
            var sessionName = sessionToRemove.GetDisplayName();
            bool confirmed;
            try
            {
                confirmed = await JSRuntime.InvokeAsync<bool>("confirm", string.Format(L["Root.Confirm.DeleteSessionFormat"], sessionName));
            }
            catch (JSDisconnectedException)
            {
                return;
            }
            catch (Exception)
            {
                return;
            }
            if (!confirmed)
            {
                return;
            }
            
            // ConPtySessionのクリーンアップ
            if (sessionToRemove.ConPtySession != null)
            {
                sessionToRemove.ConPtySession.Dispose();
            }
        }

        // セッションのタイマーを停止
        OutputAnalyzerService.StopSessionTimer(sessionId);

        // 通知ベルを掃除（残すと診断履歴上も宙に浮くため、削除時点でOFFを記録）
        if (_notificationPendingSessions.Remove(sessionId))
        {
            RecordBellHistory(sessionId, "OFF", null, "RemoveSession(セッション削除)");
        }

        // アクティブセッションの場合の追加処理
        if (sessionId == activeSessionId)
        {

            if (activeTerminal != null)
            {
                await activeTerminal.DisposeAsync();
                activeTerminal = null;
            }
        }

        // ターミナルのクリーンアップはdestroyTerminalで処理される

        await SessionManager.RemoveSessionAsync(sessionId);
        await DeleteSessionFromStorageAsync(sessionId);
        sessions = SessionManager.GetAllSessions().ToList();

        if (activeSessionId == sessionId)
        {
            activeSessionId = null;
            activeSession = null;

            // セッション削除を即座にUIに反映
            StateHasChanged();

            await SaveActiveSessionIdToStorageAsync(null);

            // 他のセッションがあれば最初のものを選択
            if (sessions.Any())
            {
                await SelectSession(sessions.First().SessionId);
            }
        }
        else
        {
            // 削除されたセッションがアクティブでない場合もUIを更新
            StateHasChanged();
        }
    }

    private async Task ArchiveSession(Guid sessionId)
    {
        var sessionToArchive = sessions.FirstOrDefault(s => s.SessionId == sessionId);
        if (sessionToArchive == null) return;

        var sessionName = sessionToArchive.GetDisplayName();
        bool confirmed;
        try
        {
            confirmed = await JSRuntime.InvokeAsync<bool>("confirm", string.Format(L["Root.Confirm.ArchiveSessionFormat"], sessionName));
        }
        catch (JSDisconnectedException)
        {
            return;
        }
        catch (Exception)
        {
            return;
        }
        if (!confirmed) return;

        // セッションのタイマーを停止
        OutputAnalyzerService.StopSessionTimer(sessionId);

        // 通知ベルを掃除（残すとアーカイブ復帰時に古いベルが再表示されるため）
        if (_notificationPendingSessions.Remove(sessionId))
        {
            RecordBellHistory(sessionId, "OFF", null, "ArchiveSession(アーカイブ)");
        }

        // アクティブセッションの場合の追加処理
        if (sessionId == activeSessionId)
        {
            if (activeTerminal != null)
            {
                await activeTerminal.DisposeAsync();
                activeTerminal = null;
            }
        }

        // SessionManagerでアーカイブ処理（ConPtySessionの破棄含む）
        SessionManager.ArchiveSession(sessionId);
        if (_storageService != null)
        {
            await _storageService.UpdateArchivedStateAsync(sessionId, true, DateTime.Now);
        }

        sessions = SessionManager.GetAllSessions().ToList();

        if (activeSessionId == sessionId)
        {
            activeSessionId = null;
            activeSession = null;
            await SaveActiveSessionIdToStorageAsync(null);

            // アーカイブされていない他のセッションがあれば最初のものを選択
            var activeSessionsList = SessionManager.GetActiveSessions().ToList();
            if (activeSessionsList.Any())
            {
                await SelectSession(activeSessionsList.First().SessionId);
            }
        }

        StateHasChanged();
    }

    private async Task RestoreArchivedSession(Guid sessionId)
    {
        try
        {
            // SessionManagerでアーカイブから復元
            var restoredSession = await SessionManager.RestoreArchivedSessionAsync(sessionId);
            if (restoredSession == null)
            {
                Logger.LogWarning("アーカイブセッションの復元に失敗しました: {SessionId}", sessionId);
                return;
            }

            // SessionManagerから最新のセッションリストを取得
            sessions = SessionManager.GetAllSessions().ToList();

            // ローカルストレージを更新
            await SaveSessionToStorageAsync(restoredSession);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "アーカイブセッションの復元に失敗しました: {SessionId}", sessionId);
        }
    }

    private async Task DeleteArchivedSession(Guid sessionId)
    {
        SessionManager.DeleteSession(sessionId);
        await DeleteSessionFromStorageAsync(sessionId);
        bottomPanel?.RemoveMemoTabsForSession(sessionId);

        sessions = SessionManager.GetAllSessions().ToList();
        StateHasChanged();
    }

    private async Task DeleteAllArchivedSessions()
    {
        var archivedSessions = SessionManager.GetAllSessions().Where(s => s.IsArchived).ToList();
        foreach (var session in archivedSessions)
        {
            SessionManager.DeleteSession(session.SessionId);
            await DeleteSessionFromStorageAsync(session.SessionId);
            bottomPanel?.RemoveMemoTabsForSession(session.SessionId);
        }

        sessions = SessionManager.GetAllSessions().ToList();
        StateHasChanged();
    }

    private List<SessionInfo> GetArchivedSessions()
    {
        return SessionManager.GetAllSessions().Where(s => s.IsArchived).ToList();
    }

    [JSInvokable]
    public async Task SendInput(string sessionId, string data)
    {
        // ShellPanelからの入力を処理
        if (sessionId.StartsWith("shell-term-"))
        {
            var panelId = sessionId.Replace("shell-term-", "");
            if (shellPanelRefs.TryGetValue(panelId, out var shellPanel))
            {
                await shellPanel.WriteInput(data ?? string.Empty);
            }
        }
        else
        {
            // 通常のセッションからの入力を処理
            var guid = Guid.Parse(sessionId);
            if (activeSession != null && guid == activeSessionId)
            {
                await activeSession.WriteAsync(data ?? string.Empty);
            }
        }
    }

    [JSInvokable]
    public void OnTerminalSizeChanged(string sessionId, int cols, int rows,
        string source = "", string detail = "", string dupSource = "")
    {
        // ログ用の短縮セッションID（source/detail/dupSourceは診断ログ専用、二重通知抑制はJS側で完結）
        var shortId = sessionId.Length > 8 ? sessionId.Substring(0, 8) : sessionId;

        if (Logger.IsEnabled(LogLevel.Debug))
        {
            var dupInfo = !string.IsNullOrEmpty(dupSource) ? $" dup={dupSource}" : "";
            var detailInfo = !string.IsNullOrEmpty(detail) ? $" ({detail})" : "";
            Logger.LogDebug("[Resize] JS→C#: {Cols}x{Rows} src={Source}{Detail}{Dup} session={SessionId}",
                cols, rows, source, detailInfo, dupInfo, shortId);
        }

        // ShellPanelのサイズ変更を処理
        if (sessionId.StartsWith("shell-term-"))
        {
            var panelId = sessionId.Replace("shell-term-", "");
            if (shellPanelRefs.TryGetValue(panelId, out var shellPanel))
            {
                shellPanel.SendResize(cols, rows);
            }
        }
        else
        {
            // 通常のセッションのサイズ変更を処理
            if (!Guid.TryParse(sessionId, out var guid))
            {
                return;
            }
            if (guid == activeSessionId && activeSession != null)
            {
                // セッション再選択時のfit()によるリサイズはConPTYに通知しない
                // ConPTYリサイズは画面内容を再送信するため、重複が発生する
                if (_skipConPtyResize)
                {
                    if (Logger.IsEnabled(LogLevel.Debug))
                    {
                        Logger.LogDebug("[Resize] ConPTYスキップ(切替中): {Cols}x{Rows} src={Source} session={SessionId}",
                            cols, rows, source, shortId);
                    }
                    return;
                }

                // ConPTY リサイズは【即時】適用する（デバウンス禁止）。
                // Claude Code はストリーミング中、更新のたびに全画面を ESC[H から再描画する。
                // フレームはサイズが一致していれば上書きで無害だが、「xterm の行数 < CLI が信じる行数」の
                // 期間はフレーム下端があふれ、上端行がフレームごとにスクロールバックへ漏れて多重化する
                // （実キャプチャで確認: デバウンスするとドラッグ中ずっと不一致が続き、漏れが蓄積した）。
                // ミスマッチ時間を最小化するため即時適用。同サイズは ConPtySession.Resize 側でガード済み。
                ApplyConPtyResize(guid, cols, rows, shortId);
            }
            else if (guid != activeSessionId)
            {
                if (Logger.IsEnabled(LogLevel.Debug))
                {
                    Logger.LogDebug("[Resize] 非アクティブ(無視): {Cols}x{Rows} src={Source} session={SessionId}",
                        cols, rows, source, shortId);
                }
            }
        }
    }

    /// <summary>
    /// ConPTY へのリサイズを即時適用する。
    /// Claude Code 等の TUI はリサイズ(WINCH)や更新のたびに ESC[H アンカーで全画面を再描画するため、
    /// サイズさえ一致していれば再描画は上書きで無害。逆にサイズ不一致の期間があると
    /// フレーム下端があふれて上端行がスクロールバックへ漏れるため、不一致時間の最小化が最重要。
    /// </summary>
    private void ApplyConPtyResize(Guid guid, int cols, int rows, string shortId)
    {
        if (activeSession == null)
        {
            return;
        }

        // 同サイズなら何もしない（ConPtySession.Resize 側にもガードあり）
        if (activeSession.Cols == cols && activeSession.Rows == rows)
        {
            return;
        }

        Logger.LogInformation("[Resize] ConPTY適用: {PrevCols}x{PrevRows}→{Cols}x{Rows} session={SessionId}",
            activeSession.Cols, activeSession.Rows, cols, rows, shortId);

        var selectedSession = sessions.FirstOrDefault(s => s.SessionId == guid);

        bool rowsGrew = rows > activeSession.Rows;

        // 状態バッファ（エミュレータ方式）のグリッドサイズも同時に追随させる。
        // グリッドと ConPTY の行数が常に一致していれば、TUI の全画面再描画フレームは
        // グリッド上でも正確に上書きとして畳まれ、スクロールバックは汚れない
        selectedSession?.ResizeTerminalBuffer(cols, rows);

        // ConPtyにリサイズを通知（activeSession と selectedSession.ConPtySession は同一インスタンス。
        // 以前は両方に Resize を呼んでいたため ResizePseudoConsole が2回走り多重化の原因になっていた）
        activeSession.Resize(cols, rows);

        // 行数「増加」時は xterm をエミュレータ状態から再同期する（デバウンス付き）。
        // conhost は行数増加でスクロール履歴から行を引き戻してビューポートに含め、TUI の
        // 再描画フレームにもその行が現れるが、xterm.js はスクロールバックから同じ行を
        // 取り除かないため、境界の行がスクロールバックとビューポートに二重に残る
        // （従来からの「リサイズで二重化」の正体）。エミュレータのグリッドは conhost と
        // 同じ引き戻し規則で管理しているので、その確定状態で xterm を作り直せば解消する。
        if (rowsGrew)
        {
            _ = ScheduleEmulatorResyncAsync(guid);
        }
    }

    // 行数増加後の xterm 再同期のデバウンス制御（ドラッグ完了後に1回だけ実行）
    private CancellationTokenSource? _emulatorResyncCts;
    private const int EmulatorResyncDebounceMs = 400;

    /// <summary>
    /// xterm をフルリセット（RIS: 画面＋スクロールバック消去）し、エミュレータの確定状態を
    /// 書き戻して再同期する。リセットと再生を1回の書き込みに連結し、順序を原子的に保証する。
    /// </summary>
    private async Task ScheduleEmulatorResyncAsync(Guid guid)
    {
        var previousCts = _emulatorResyncCts;
        previousCts?.Cancel();
        previousCts?.Dispose();
        var cts = new CancellationTokenSource();
        _emulatorResyncCts = cts;

        try
        {
            await Task.Delay(EmulatorResyncDebounceMs, cts.Token);
        }
        catch (TaskCanceledException)
        {
            return; // より新しい再同期要求に置き換えられた
        }

        if (cts.IsCancellationRequested || _skipConPtyResize || guid != activeSessionId || activeTerminal == null)
        {
            return;
        }

        var session = sessions.FirstOrDefault(s => s.SessionId == guid);
        if (session == null)
        {
            return;
        }

        try
        {
            // ライブ出力と交錯すると1行ズレ・重複が起きるため、書き込みロック下で
            // スナップショット→テールの順に書き込む（スナップショット以降のライブ出力はテールで届く）
            await _terminalWriteLock.WaitAsync();
            try
            {
                var snapshot = session.BeginTerminalBufferReplay();
                string tail;
                try
                {
                    // ESC c (RIS) は xterm.js でスクロールバックを含む完全リセット
                    await TerminalService.WriteToTerminalAsync(activeTerminal, "\x1bc" + snapshot.Content);
                }
                finally
                {
                    tail = session.EndTerminalBufferReplay(snapshot);
                }
                if (!string.IsNullOrEmpty(tail))
                {
                    await TerminalService.WriteToTerminalAsync(activeTerminal, tail);
                }
                Logger.LogInformation("[Resize] エミュレータ再同期完了: {Size}文字＋テール{TailSize}文字 session={SessionId}",
                    snapshot.Content.Length, tail.Length, guid.ToString().Substring(0, 8));
            }
            finally
            {
                _terminalWriteLock.Release();
            }
        }
        catch (JSDisconnectedException)
        {
            // 回線切断時は何もしない
        }
        catch (Exception ex)
        {
            // fire-and-forget 呼び出しのため、未観測例外にしない（circuit 破棄後の ObjectDisposedException 等）
            Logger.LogDebug(ex, "[Resize] エミュレータ再同期をスキップ: session={SessionId}", guid);
        }
    }

    /// <summary>
    /// フロー制御: クライアント側のバッファが溜まりすぎた時に呼ばれる
    /// ConPTYからの出力読み取りを一時停止する
    /// </summary>
    [JSInvokable]
    public void OnFlowControlPause(string sessionId)
    {
        if (!Guid.TryParse(sessionId, out var guid))
            return;

        var session = sessions.FirstOrDefault(s => s.SessionId == guid);
        if (session?.ConPtySession != null)
        {
            session.ConPtySession.PauseOutput();
            Logger.LogDebug("Flow control: Paused output for session {SessionId}", sessionId);
        }
    }

    /// <summary>
    /// フロー制御: クライアント側のバッファが処理されたら呼ばれる
    /// ConPTYからの出力読み取りを再開する
    /// </summary>
    [JSInvokable]
    public void OnFlowControlResume(string sessionId)
    {
        if (!Guid.TryParse(sessionId, out var guid))
            return;

        var session = sessions.FirstOrDefault(s => s.SessionId == guid);
        if (session?.ConPtySession != null)
        {
            session.ConPtySession.ResumeOutput();
            Logger.LogDebug("Flow control: Resumed output for session {SessionId}", sessionId);
        }
    }

    private async Task DestroyTerminal(Guid sessionId, bool showAlert = true)
    {
        try
        {
            // JavaScript側のターミナルを破棄
            await TerminalService.DestroyTerminalAsync(sessionId, showAlert);

            // C#側のターミナル参照を削除（アクティブセッションの場合のみ）
            if (activeSessionId == sessionId && activeTerminal != null)
            {
                await activeTerminal.DisposeAsync();
                activeTerminal = null;
            }

            if (showAlert)
            {
                toast?.ShowSuccess(L["Root.Toast.TerminalDisposed"]);
            }
        }
        catch (Exception ex)
        {
            if (showAlert)
            {
                toast?.ShowError(string.Format(L["Root.Toast.TerminalDisposeErrorFormat"], ex.Message));
            }
        }
    }

    private async Task RecreateTerminal(Guid sessionId)
    {
        try
        {
            // セッションがアクティブな場合のみ再作成
            if (activeSessionId == sessionId)
            {
                // 既存のターミナルを破棄（アラートなし）
                await DestroyTerminal(sessionId, false);

                // 新しいターミナルを初期化
                await InitializeTerminal(sessionId);

                // ターミナル再作成処理
                var selectedSessionInfo = sessions.FirstOrDefault(s => s.SessionId == sessionId);
                await TerminalService.RecreateTerminalAsync(sessionId, selectedSessionInfo!, activeSession);

                // ConPtyConnectionServiceに再登録
                if (selectedSessionInfo?.ConPtySession != null)
                {
                    selectedSessionInfo.LastConnectionTime = DateTime.Now;
                    ConPtyConnection.SubscribeToSession(selectedSessionInfo.SessionId, selectedSessionInfo.ConPtySession);
                }

                toast?.ShowSuccess(L["Root.Toast.TerminalRecreated"]);
            }
            else
            {
                toast?.ShowWarning(L["Root.Toast.SelectSessionFirst"]);
            }
        }
        catch (Exception ex)
        {
            toast?.ShowError(string.Format(L["Root.Toast.TerminalRecreateErrorFormat"], ex.Message));
        }
    }





    private async Task SendInput()
    {

        if (activeSession == null)
        {
            return;
        }

        var currentSession = sessions.FirstOrDefault(s => s.SessionId == activeSessionId);
        if (currentSession == null)
        {
            return;
        }

        // テキストがある場合は送信
        if (!string.IsNullOrWhiteSpace(inputText))
        {
            // テキスト履歴に追加
            InputHistoryService.AddToHistory(inputText);

            await activeSession.WriteAsync(inputText);

            // 最終利用時刻を更新（ソート用）
            if (activeSessionId.HasValue)
            {
                var sessionInfo = SessionManager.GetSessionInfo(activeSessionId.Value);
                if (sessionInfo != null)
                {
                    Logger.LogInformation("[LastAccessedAt更新] きっかけ: SendInput(入力送信), セッション: {SessionName}", sessionInfo.GetDisplayName());
                    sessionInfo.LastAccessedAt = DateTime.Now;
                    await SaveSessionToStorageAsync(sessionInfo);
                    StateHasChanged();
                }
            }

            // テキスト送信後、Enter送信前に0.2秒待機
            await Task.Delay(200);
        }

        // Enterキーを送信（空の場合でも送信）
        await SendEnterKeyDirect();

        // 入力フィールドをクリア
        inputText = "";
    }

    private async Task OnTextAreaKeyDown(KeyboardEventArgs e)
    {
        // Enter で送信（Shiftキーが押されていない場合）
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendInput();
        }
        // Ctrl+C: 強制中断
        else if (e.Key == "c" && e.CtrlKey && !e.AltKey && !e.ShiftKey)
        {
            await SendCtrlC();
        }
        // Escape: 中断
        else if (e.Key == "Escape")
        {
            await SendEscape();
        }
        // モード切替（ClaudeCodeモードのみ）- Alt+M または Shift+Tab（設定による）
        else if ((claudeModeSwitchKey == "altM" && e.Key == "m" && e.AltKey && !e.CtrlKey && !e.ShiftKey) ||
                 (claudeModeSwitchKey == "shiftTab" && e.Key == "Tab" && e.ShiftKey && !e.CtrlKey && !e.AltKey))
        {
            var currentSession = sessions.FirstOrDefault(s => s.SessionId == activeSessionId);
            if (currentSession?.TerminalType == TerminalType.ClaudeCode)
            {
                await SendModeSwitch();
            }
        }
        // 履歴機能: 上矢印で前の履歴、下矢印で次の履歴
        else if (e.Key == "ArrowUp" && e.CtrlKey)
        {
            var historyText = InputHistoryService.NavigateHistory(-1);
            if (historyText != null)
                inputText = historyText;
        }
        else if (e.Key == "ArrowDown" && e.CtrlKey)
        {
            var historyText = InputHistoryService.NavigateHistory(1);
            if (historyText != null)
                inputText = historyText;
        }
        // Shift+Enter は通常の改行動作（何もしない）
    }

