@page "/"
@rendermode InteractiveServer
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>wterm PoC</PageTitle>

<div class="wterm-poc-root">
    <div id="terminal" class="wterm-poc-terminal"></div>
    <div class="wterm-poc-input">
        <textarea @bind="inputText" rows="3" class="form-control" placeholder="ターミナルに送るテキストを入力" disabled="@(!isReady)"></textarea>
        <button class="btn btn-primary mt-2" @onclick="SendAsync" disabled="@(!isReady)">送信</button>
    </div>
</div>

<style>
    .wterm-poc-root {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 6rem);
        gap: 0.5rem;
    }
    .wterm-poc-terminal {
        flex: 7 1 0;
        min-height: 0;
        background: #000;
        color: #ccc;
        overflow: hidden;
    }
    .wterm-poc-input {
        flex: 3 1 0;
        display: flex;
        flex-direction: column;
        min-height: 0;
    }
    .wterm-poc-input textarea {
        flex: 1 1 auto;
        min-height: 0;
        resize: none;
    }
</style>

@code {
    private string inputText = "";
    private bool isReady;
    private IJSObjectReference? module;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/wterm-poc.js");
                await module.InvokeVoidAsync("init", "terminal");
                isReady = true;
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Console.Error.WriteLine($"[wterm-poc] init failed: {ex}");
            }
        }
    }

    private async Task SendAsync()
    {
        if (module is null || string.IsNullOrEmpty(inputText)) return;
        await module.InvokeVoidAsync("write", inputText + "\r\n");
        inputText = "";
    }

    public async ValueTask DisposeAsync()
    {
        if (module is not null)
        {
            try
            {
                await module.InvokeVoidAsync("dispose");
                await module.DisposeAsync();
            }
            catch { }
        }
    }
}
