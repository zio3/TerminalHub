@page "/"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject IConPtyService ConPty
@inject ILogger<Home> Logger
@implements IAsyncDisposable
@using WtermPoC.Services

<PageTitle>wterm PoC</PageTitle>

<div class="wterm-poc-root">
    <div id="terminal" class="wterm-poc-terminal"></div>
    <div class="wterm-poc-input">
        <textarea @bind="inputText" rows="3" class="form-control"
                  placeholder="ConPTY に送るコマンドを入力 (例: dir)" disabled="@(!isReady)"></textarea>
        <button class="btn btn-primary mt-2" @onclick="SendAsync" disabled="@(!isReady)">送信</button>
    </div>
</div>

<style>
    .wterm-poc-root {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 6rem);
        gap: 0.5rem;
    }
    .wterm-poc-terminal {
        flex: 7 1 0;
        min-height: 0;
        background: #000;
        color: #ccc;
        overflow: hidden;
    }
    .wterm-poc-input {
        flex: 3 1 0;
        display: flex;
        flex-direction: column;
        min-height: 0;
    }
    .wterm-poc-input textarea {
        flex: 1 1 auto;
        min-height: 0;
        resize: none;
    }
</style>

@code {
    private string inputText = "";
    private bool isReady;
    private IJSObjectReference? module;
    private ConPtySession? session;
    private DotNetObjectReference<Home>? dotnetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/wterm-poc.js");
                dotnetRef = DotNetObjectReference.Create(this);
                await module.InvokeVoidAsync("init", "terminal", dotnetRef);

                session = await ConPty.CreateSessionAsync("pwsh.exe", "-NoLogo", null, 80, 24);
                session.DataReceived += OnConPtyData;
                session.ProcessExited += OnProcessExited;
                session.Start();

                isReady = true;
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "[wterm-poc] init failed");
            }
        }
    }

    [JSInvokable]
    public Task OnTerminalResize(int cols, int rows)
    {
        Logger.LogInformation("[OnTerminalResize] {Cols}x{Rows}", cols, rows);
        try { session?.Resize(cols, rows); }
        catch (Exception ex) { Logger.LogError(ex, "[wterm-poc] Resize failed"); }
        return Task.CompletedTask;
    }

    [JSInvokable]
    public async Task OnTerminalData(string data)
    {
        if (session is null) return;
        try { await session.WriteAsync(data); }
        catch (Exception ex) { Logger.LogError(ex, "[wterm-poc] OnTerminalData WriteAsync failed"); }
    }

    private void OnConPtyData(object? sender, DataReceivedEventArgs e)
    {
        var data = e.Data;
        Logger.LogInformation("[OnConPtyData] len={Len} preview={Preview}", data.Length, data.Length > 60 ? data.Substring(0, 60) : data);
        _ = InvokeAsync(async () =>
        {
            if (module is null) return;
            try
            {
                await module.InvokeVoidAsync("write", data);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "[wterm-poc] write failed");
            }
        });
    }

    private void OnProcessExited(object? sender, EventArgs e)
    {
        _ = InvokeAsync(async () =>
        {
            if (module is null) return;
            try
            {
                await module.InvokeVoidAsync("write", "\r\n[process exited]\r\n");
            }
            catch { }
        });
    }

    private async Task SendAsync()
    {
        if (session is null || string.IsNullOrEmpty(inputText)) return;
        try
        {
            await session.WriteAsync(inputText + "\r");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "[wterm-poc] WriteAsync failed");
        }
        inputText = "";
    }

    public async ValueTask DisposeAsync()
    {
        if (session is not null)
        {
            try
            {
                session.DataReceived -= OnConPtyData;
                session.ProcessExited -= OnProcessExited;
                session.Dispose();
            }
            catch { }
            session = null;
        }
        if (module is not null)
        {
            try
            {
                await module.InvokeVoidAsync("dispose");
                await module.DisposeAsync();
            }
            catch { }
            module = null;
        }
    }
}
